# Anthropic API key (required) — also powers native web search for KYB lookups
ANTHROPIC_API_KEY=

# Optional: disable Anthropic web search and use Tavily/DuckDuckGo only
# USE_ANTHROPIC_WEB_SEARCH=false

# Optional fallback search if Anthropic web search is unavailable
TAVILY_API_KEY=

# Auto-confirm threshold (0.0–1.0). Below this, user must confirm entity on Step 2.
KYB_IDENTITY_CONFIDENCE=0.8

# Disk cache for LLM/search responses (avoids repeat API spend for same inputs)
API_CACHE_ENABLED=true
# Cache TTL in hours (default 168 = 7 days). Set 0 for no expiry.
API_CACHE_TTL_HOURS=168
