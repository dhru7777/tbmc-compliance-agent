# Anthropic API key — document extraction (Agent 1)
ANTHROPIC_API_KEY=

# Second key — research planner + public web search (Agent 2/3)
ANTHROPIC_API_KEY_RESEARCH=

# Public search: Anthropic built-in web search (Brave-backed). No DuckDuckGo API needed.
USE_ANTHROPIC_WEB_SEARCH=true
# Max web searches per bounded public lookup (1 keeps cost low)
KYB_BOUNDED_WEB_SEARCH_MAX_USES=1
# Optional fallback only if Anthropic web search is disabled/unavailable:
# TAVILY_API_KEY=

# Token budgets for bounded public search (yes/no verification)
KYB_SEARCH_INPUT_BUDGET=1500
KYB_SEARCH_OUTPUT_MAX=300
# Cheaper model for all LLM calls (e.g. claude-haiku-4-5)
# KYB_LLM_MODEL=claude-haiku-4-5
KYB_PLANNER_OUTPUT_MAX=600

# Print per-call + run total LLM cost to terminal (uvicorn stdout)
KYB_LOG_LLM_COST=true

# Auto-confirm threshold (0.0–1.0). Below this, user must confirm entity on Step 2.
KYB_IDENTITY_CONFIDENCE=0.8

# Disk cache for LLM/search responses (avoids repeat API spend for same inputs)
API_CACHE_ENABLED=true
# Cache TTL in hours (default 168 = 7 days). Set 0 for no expiry.
API_CACHE_TTL_HOURS=168

# PostgreSQL — same DATABASE_URL locally and on Railway
# Local Docker (port 5433 avoids conflict with Mac/Homebrew Postgres on 5432)
# DATABASE_URL=postgresql://tbmc:tbmc@127.0.0.1:5433/tbmc_kyb
DATABASE_URL=

# KYB credential validity (days from verification)
KYB_EXPIRY_DAYS=180

# Stage 2 confidence floor — below this, auto-flag even if checklist passes
KYB_CONFIDENCE_FLOOR=0.7

# Credit limit = KYB_CREDIT_LIMIT_FRACTION * monthly_volume_low * confidence_score
KYB_CREDIT_LIMIT_FRACTION=0.20
# When monthly volume is left blank on the form (demo default — not $1)
KYB_DEFAULT_MONTHLY_VOLUME_LOW=100000
KYB_DEFAULT_MONTHLY_VOLUME_HIGH=250000

# Ed25519 clearinghouse signing key (generate: python scripts/generate_signing_key.py)
# KYB_SIGNING_PRIVATE_KEY=
# KYB_SIGNING_PUBLIC_KEY=
# KYB_SIGNING_KEY_ID=tbmc-clearinghouse-2026

# Production (Railway): comma-separated frontend URLs
# CORS_ORIGINS=https://your-site.netlify.app
# CORS_ORIGIN_REGEX=https://.*\.netlify\.app
